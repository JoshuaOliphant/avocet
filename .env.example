# Copy this file to .env and fill in your credentials.
# Avocet loads .env automatically on launch; real environment variables take
# precedence over values set here.

# Raindrop.io API token (app.raindrop.io/settings/integrations -> create app -> test token)
RAINDROP=

# Anthropic API key, used to generate bookmark summaries
ANTHROPIC_API_KEY=
