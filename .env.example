# Copy this file to .env and fill in your credentials.
# Avocet loads .env automatically on launch; real environment variables take
# precedence over values set here.

# Raindrop.io API token (app.raindrop.io/settings/integrations -> create app -> test token)
RAINDROP=

# Bookmark summaries are generated by an LLM. Provide a key for ONE provider:
#   - Anthropic (Claude), or
#   - OpenAI.
# If both keys are present, Anthropic is used unless AVOCET_SUMMARY_PROVIDER says otherwise.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: force a provider ("anthropic" or "openai"). Auto-detected from the
# key you set when left blank.
# AVOCET_SUMMARY_PROVIDER=

# Optional: override the model (defaults: claude-haiku-4-5 / gpt-5-mini).
# AVOCET_SUMMARY_MODEL=
